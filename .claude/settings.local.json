{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "mcp__gossipcat__gossip_relay",
      "mcp__gossipcat__gossip_signals"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "gossipcat"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat .gossip/bootstrap.md 2>/dev/null || echo '[gossipcat] No bootstrap yet. Load tools first: ToolSearch(query: \"select:mcp__gossipcat__gossip_status\") then call gossip_status()'"
          }
        ]
      }
    ]
  }
}
