{
  "solo-builder": {
    "name": "Solo Builder",
    "description": "CLIs, scripts, small libs, prototypes",
    "roles": [
      { "preset": "implementer", "focus": "code + tests" },
      { "preset": "tester", "focus": "edge cases, validation" }
    ],
    "signals": {
      "keywords": ["cli", "script", "utility", "tool", "prototype", "poc", "simple"],
      "files": ["bin/", "*.sh"],
      "packages": ["commander", "yargs", "inquirer", "chalk", "ora"]
    }
  },
