{
  "name": "gossip-v2",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "jest --config jest.config.base.js",
    "clean": "rm -rf packages/*/dist apps/*/dist dist-mcp/",
    "build:mcp": "npx esbuild apps/cli/src/mcp-server-sdk.ts --bundle --platform=node --target=node22 --outfile=dist-mcp/mcp-server.js --external:ws --external:@modelcontextprotocol/sdk --tsconfig=tsconfig.json",
    "gossipcat": "npx ts-node -r tsconfig-paths/register -P tsconfig.json apps/cli/src/index.ts",
    "start": "npx ts-node -r tsconfig-paths/register -P tsconfig.json apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "tsconfig-paths": "^4.2.0"
  }
}
